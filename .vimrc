set autoindent
set expandtab
set shiftround
set shiftwidth=4
set smarttab
set tabstop=4

set linebreak
set sidescrolloff=5
syntax enable
filetype plugin on
set omnifunc=syntaxcomplete#Complete
set wrap
set relativenumber
set background=dark
set backspace=indent,eol,start

set nocompatible
set path+=**
set wildmenu
