set autoindent
set expandtab
set shiftround
set shiftwidth=2
set smarttab
set tabstop=2

set linebreak
set sidescrolloff=5
syntax enable
set nowrap
filetype plugin on
set omnifunc=syntaxcomplete#Complete
set relativenumber
set background=dark
set backspace=indent,eol,start
colorscheme pablo

set nocompatible
set path+=**
set wildmenu

set foldmethod=indent
hi Folded ctermbg=NONE guibg=NONE
set foldnestmax=2
